{
    "birth1": {
        "name": "birth1",
        "title": "你出生了 - 平凡",
        "text": "在一个风和日丽的雨天，室内散发着焦灼的气息，呻吟声和踱步声清晰可辨。不算富有也不算贫穷，你的父母怀着激动的心情期待着你的降世。随着一声清晰的啼哭划破雨夜，你出生在这个世界上",
        "conditions": {
            "age_limit_min": 0,
            "age_limit_max": 0
        },
        "weight": 256,
        "options": [
            {
                "text": "大声哭闹",
                "conditions": {},
                "result": {
                    "branches": [
                        {
                            "conditions": {},
                            "result_str": "你健康而响亮的哭声让大家都松了口气，产婆预言你将是个活泼好动的孩子。",
                            "effect": {
                                "add_traits": ["活泼"]
                            }
                        }
                    ]
                }
            },
            {
                "text": "睁开双眼",
                "conditions": {},
                "result": {
                    "branches": [
                        {
                            "conditions": {},
                            "result_str": "尽管你还不适应强光的刺眼，你还是坚持睁开了眼皮，努力打量着这个世界。",
                            "effect": {
                                "sub_event": "choose_eye"
                            }
                        }
                    ]
                }
            },
            {
                "text": "试说脏话",
                "conditions": {},
                "result": {
                    "branches": [
                        {
                            "conditions": {},
                            "result_str": "尽管刚刚出生，你已经无师自通地学会了一句令人不寒而栗的侮辱性文字，你向这个世界控诉着从娘胎里出来的痛苦。",
                            "effect": {
                                "add_traits": ["高素质","天才"]
                            }
                        }
                    ]
                }
            },
            {
                "text": "安稳睡觉",
                "conditions": {},
                "result": {
                    "branches": [
                        {
                            "conditions": {},
                            "result_str": "你的哭声很快安静下来，在大人们惊吓之余，你早已经睡得安详，不需要惊天动地，你安安静静地进入了你的角色。",
                            "effect": {
                                "add_traits": ["冷静"]
                            }
                        }
                    ]
                }
            }
        ]
